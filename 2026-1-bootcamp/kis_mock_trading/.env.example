# KIS(한국투자증권) 모의투자 API 설정
# 1. https://apiportal.koreainvestment.com/ 에서 모의투자 APP 신청 후 발급
# 2. 이 파일을 .env로 복사하고 실제 값으로 채워주세요: cp .env.example .env

KIS_APP_KEY=모의투자_앱키_입력
KIS_APP_SECRET=모의투자_앱시크릿_입력

# 모의투자 계좌번호 8자리 (예: 50000001)
# HTS/MTS에서 모의투자 계좌 개설 후 확인 가능
KIS_ACCOUNT_NO=모의투자_계좌번호_8자리_입력

# 모의투자 모드 (true = 모의투자, false = 실전투자)
MOCK_MODE=true